+        var sink = new RecordingSideEffectSink();
+        var route = new SimulatedCapabilityRouter().Route("ledger_append", sink);
+        return (route.Decision.ToString(), route.SelectedExecutor, NoExecutionProof.FromSink(sink));
+    }
