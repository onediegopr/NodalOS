{
  "project": "NODAL OS",
  "milestone": "M985",
  "mode": "audit-only / intake-only",
  "schemaName": "claude-audit-findings-intake",
  "acceptedFields": [
    "audit_id",
    "auditor",
    "audit_date",
    "base_commit",
    "decision",
    "overall_summary",
    "findings",
    "severity",
    "affected_scope",
    "blocking_status",
    "manual_qa_eligibility",
    "runtime_eligibility",
    "release_eligibility",
    "required_remediations",
    "recommended_tests",
    "auditor_notes"
  ],
  "allowedDecisions": ["AUDIT_GO", "AUDIT_CONDITIONAL_GO", "AUDIT_NO_GO"],
  "allowedSeverities": ["BLOCKER", "HIGH", "MEDIUM", "LOW", "NIT"],
  "rejectInvalidIf": [
    "no base_commit",
    "no decision",
    "any finding missing severity",
    "declares manual QA ready without evidence",
    "declares runtime ready",
    "declares release ready",
    "ignores BrowserRuntimeSmoke caveat",
    "ignores product files / Bridge/CSP boundary",
    "ignores no-side-effect boundary"
  ],
  "defaultEligibilityWhenUnproven": {
    "manual_qa_eligibility": "NOT_READY_EVIDENCE_PENDING",
    "runtime_eligibility": "NO-GO",
    "release_eligibility": "NO-GO"
  },
  "intakeStatus": "AWAITING_CLAUDE_AUDIT",
  "noFindingsFabricated": true
}
