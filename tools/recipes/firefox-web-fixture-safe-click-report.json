{
  "name": "firefox-web-fixture-safe-click-report",
  "description": "HITO-040 diagnostic: open accessible fixture in Firefox, preflight+approval+safe.click 'Abrir informacion' target.",
  "stopOnFirstFailure": true,
  "metadata": {
    "category": "diagnostic",
    "cleanupRisk": "low",
    "autoRegression": false,
    "flaky": true,
    "reason": "Firefox can open a restored/new-tab window instead of the fixture when resident background processes exist. Keep as diagnostic until browser.open can verify navigation."
  },
  "steps": [
    { "id": "open-fixture", "kind": "browser.open", "path": "tools/fixtures/web/accessible-safe-click.html", "saveAs": "browser.s1", "timeoutMs": 20000, "args": { "browser": "firefox", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 8000 },
    { "id": "read-text", "kind": "browser.read", "process": "firefox", "property": "text", "saveAs": "btextBefore", "timeoutMs": 10000, "args": { "session": "browser.s1" }, "continueOnError": true },
    { "id": "preflight", "kind": "preflight.click", "saveAs": "clickPreflight", "args": { "targettext": "Abrir informaci\u00f3n" }, "continueOnError": true },
    { "id": "approval", "kind": "approval.manifest", "saveAs": "approval", "args": { "from": "clickPreflight", "mode": "nonCommercialWeb" }, "continueOnError": true },
    { "id": "safe-click", "kind": "safe.click", "saveAs": "safeClick", "args": { "targettext": "Abrir informaci\u00f3n", "proc": "firefox", "mode": "nonCommercialWeb" }, "continueOnError": true },
    { "id": "delay-after", "kind": "delay", "timeoutMs": 500 },
    { "id": "read-text-after", "kind": "browser.read", "process": "firefox", "property": "text", "saveAs": "btextAfter", "timeoutMs": 10000, "args": { "session": "browser.s1" }, "continueOnError": true },
    { "id": "close-browser", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "assert-exec-allowed", "kind": "assert.equals", "value": "{{approval.executionAllowedInThisHito}}", "expected": "true" },
    { "id": "assert-executed", "kind": "assert.equals", "value": "{{safeClick.executed}}", "expected": "true" },
    { "id": "assert-info", "kind": "assert.contains", "value": "{{btextAfter}}", "expected": "Informaci\u00f3n" },
    { "id": "report", "kind": "note", "text": "Firefox Fixture Safe Click: target={{safeClick.targetText}} result={{safeClick.result}} executed={{safeClick.executed}} reason={{safeClick.reason}}" }
  ]
}
