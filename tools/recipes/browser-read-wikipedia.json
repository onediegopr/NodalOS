{
  "name": "browser-read-wikipedia",
  "description": "Browser read: open Wikipedia Automation page, read title via UIA, close browser",
  "stopOnFirstFailure": true,
  "defaultTimeoutMs": 15000,
  "steps": [
    { "id": "open-edge", "kind": "browser.open", "path": "https://en.wikipedia.org/wiki/Automation", "saveAs": "browser.s1", "timeoutMs": 15000, "args": { "browser": "edge", "forceAccessibility": "true" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 5000 },
    { "id": "read-title", "kind": "browser.read", "process": "msedge", "property": "title", "saveAs": "browser.title", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "close-edge", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "assert-title", "kind": "assert.contains", "value": "{{browser.title}}", "expected": "Automation" },
    { "id": "note-read", "kind": "note", "text": "Wikipedia title read: {{browser.title}}" }
  ]
}
