{
  "name": "web-wikipedia-profile-report",
  "description": "Load Wikipedia profile, open owned session, read title, close, assert",
  "stopOnFirstFailure": true,
  "steps": [
    { "id": "load-profile", "kind": "profile.load", "path": "tools/profiles/web/wikipedia-automation.json", "saveAs": "profile.wiki" },
    { "id": "open-web", "kind": "browser.open", "path": "{{profile.wiki.url}}", "saveAs": "browser.s1", "timeoutMs": 15000, "args": { "browser": "edge", "forceAccessibility": "true", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 5000 },
    { "id": "read-title", "kind": "browser.read", "process": "msedge", "property": "title", "saveAs": "browser.title", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "close-web", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "assert-title", "kind": "assert.contains", "value": "{{browser.title}}", "expected": "{{profile.wiki.expected.titleContains}}" },
    { "id": "note-done", "kind": "note", "text": "Wikipedia profile report completed. Title: {{browser.title}}" }
  ]
}
