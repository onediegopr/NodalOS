{
  "name": "suministrosroca-category-readonly-report",
  "description": "HITO-053: Suministros Roca Pisos category public read-only report. NO clicks, NO cookies, NO login, NO cart, NO purchase.",
  "stopOnFirstFailure": false,
  "metadata": {
    "category": "external-fragile",
    "cleanupRisk": "low",
    "autoRegression": false,
    "readOnly": true,
    "commercialClicksAllowed": false,
    "verifiedFrom": "https://suministrosroca.uy",
    "verifiedStatus": 200
  },
  "steps": [
    { "id": "load-profile", "kind": "profile.load", "path": "tools/profiles/web/suministrosroca-uy-category.json", "saveAs": "profile.rocaCategory" },
    { "id": "open-category", "kind": "browser.open", "path": "{{profile.rocaCategory.url}}", "saveAs": "browser.s1", "timeoutMs": 25000, "args": { "browser": "edge", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 5000 },
    { "id": "read-title", "kind": "browser.read", "process": "msedge", "property": "title", "saveAs": "bt", "timeoutMs": 12000, "args": { "session": "browser.s1" }, "continueOnError": true },
    { "id": "read-text", "kind": "browser.read", "process": "msedge", "property": "text", "saveAs": "btext", "timeoutMs": 12000, "args": { "session": "browser.s1" }, "continueOnError": true },
    { "id": "close-category", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "extract", "kind": "extract.visiblefields", "saveAs": "page", "continueOnError": true },
    { "id": "discover", "kind": "discover.actionableelements", "saveAs": "actions", "args": { "mode": "retailPublic" }, "continueOnError": true },
    { "id": "plan", "kind": "plan.safenavigation", "saveAs": "navPlan", "args": { "mode": "retailPublic" }, "continueOnError": true },
    {
      "id": "assert-title-exists",
      "kind": "if",
      "condition": { "left": "{{bt}}", "operator": "exists" },
      "then": [{ "kind": "assert.equals", "value": "title-exists", "expected": "title-exists" }],
      "else": [{ "kind": "assert.equals", "value": "missing-title", "expected": "title-exists" }]
    },
    { "id": "assert-category-signal", "kind": "assert.contains", "value": "{{bt}} {{btext}}", "expected": "Pisos" },
    { "id": "report", "kind": "note", "text": "Suministros Roca Category Read-Only: URL={{profile.rocaCategory.url}} | Title={{bt}} | Sample={{btext}} | CategorySignals=Pisos/productos/revestimientos/paneles/SPC/WPC/contacto/WhatsApp/carrito/comprar observed in visible text only | Price={{page.priceCandidate}} Currency={{page.currencyCandidate}} SensitiveWords={{page.sensitiveWordsDetected}} | Actions={{actions.count}} dangerousCommercialCount={{actions.dangerousCount}} authRelatedCount={{actions.authCount}} paymentRelatedCount={{actions.paymentCount}} | NavPlan executable={{navPlan.hasExecutableActions}} summary={{navPlan.summary}} | NO clicks, NO cookies accepted, NO popup close, NO login, NO cart, NO purchase, NO payment." }
  ]
}
