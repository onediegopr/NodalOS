{
  "name": "edge-example-smoke",
  "description": "Open Edge with example.com, confirm page loaded via title. Close Edge first if already running.",
  "stopOnFirstFailure": true,
  "metadata": {
    "category": "regression",
    "cleanupRisk": "low",
    "autoRegression": true
  },
  "steps": [
    {
      "id": "open-edge",
      "kind": "browser.open",
      "path": "https://example.com",
      "saveAs": "browser.s1",
      "timeoutMs": 15000,
      "args": {
        "browser": "edge",
        "forceAccessibility": "true",
        "reuseExisting": "false"
      }
    },
    {
      "id": "delay-load",
      "kind": "delay",
      "timeoutMs": 4000
    },
    {
      "id": "read-title",
      "kind": "browser.read",
      "process": "msedge",
      "property": "title",
      "saveAs": "browser.title",
      "timeoutMs": 10000,
      "args": {
        "session": "browser.s1"
      },
      "continueOnError": true
    },
    {
      "id": "close-edge",
      "kind": "browser.close",
      "saveAs": "browser.s1",
      "timeoutMs": 5000
    },
    {
      "id": "assert-title",
      "kind": "assert.contains",
      "value": "{{browser.title}}",
      "expected": "Example"
    },
    {
      "id": "note-ok",
      "kind": "note",
      "text": "Edge loaded example.com successfully"
    }
  ]
}
