{
  "name": "firefox-external-noncommercial-safe-click-report",
  "description": "HITO-042: Open external non-commercial web in Firefox, preflight+approval+safe.click target. No hacks.",
  "stopOnFirstFailure": false,
  "steps": [
    { "id": "open-external", "kind": "browser.open", "path": "https://example.com", "saveAs": "browser.s1", "timeoutMs": 20000, "args": { "browser": "firefox", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 3000 },
    { "id": "read-before", "kind": "browser.read", "process": "firefox", "property": "title", "saveAs": "btBefore", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "preflight", "kind": "preflight.click", "saveAs": "clickPreflight", "args": { "targettext": "More information" } },
    { "id": "approval", "kind": "approval.manifest", "saveAs": "approval", "args": { "from": "clickPreflight", "mode": "nonCommercialWeb" } },
    { "id": "assert-exec-allowed", "kind": "assert.equals", "value": "{{approval.executionAllowedInThisHito}}", "expected": "true" },
    { "id": "safe-click", "kind": "safe.click", "saveAs": "safeClick", "args": { "targettext": "More information", "proc": "firefox", "mode": "nonCommercialWeb" } },
    { "id": "delay-after", "kind": "delay", "timeoutMs": 2000 },
    { "id": "read-after", "kind": "browser.read", "process": "firefox", "property": "title", "saveAs": "btAfter", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "read-text-after", "kind": "browser.read", "process": "firefox", "property": "text", "saveAs": "btextAfter", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "close-browser", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "report", "kind": "note", "text": "Firefox External: target={{safeClick.targetText}} executed={{safeClick.executed}} result={{safeClick.result}} reason={{safeClick.reason}} method={{safeClick.resolution.method}} candidateCount={{safeClick.resolution.candidateCount}} selectedName={{safeClick.resolution.selectedName}} selectedRole={{safeClick.resolution.selectedControlType}} rect={{safeClick.resolution.selectedBoundingRect}} before={{btBefore}} after={{btAfter}}" }
  ]
}
