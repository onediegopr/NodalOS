{
  "name": "visual-browser-capture",
  "description": "Visual capture: open Edge example.com, capture window region, verify path",
  "stopOnFirstFailure": true,
  "steps": [
    {
      "id": "open-edge",
      "kind": "browser.open",
      "path": "https://example.com",
      "timeoutMs": 15000,
      "args": {
        "browser": "edge",
        "forceAccessibility": "true"
      }
    },
    {
      "id": "delay-load",
      "kind": "delay",
      "timeoutMs": 4000
    },
    {
      "id": "capture-browser",
      "kind": "visual.capture",
      "args": {
        "mode": "window"
      },
      "process": "msedge",
      "out": "artifacts/recipes/browser-capture.png",
      "saveAs": "visual.browserCapture",
      "timeoutMs": 10000
    },
    {
      "id": "assert-path-set",
      "kind": "assert.contains",
      "value": "{{visual.browserCapture.path}}",
      "expected": "browser-capture",
      "ignoreCase": false
    },
    {
      "id": "note-metadata",
      "kind": "note",
      "text": "Capture: {{visual.browserCapture.path}} ({{visual.browserCapture.width}}x{{visual.browserCapture.height}})"
    }
  ]
}
