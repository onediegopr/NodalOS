{
  "name": "noncommercial-web-safe-click-report",
  "description": "Non-commercial safe click: evaluates preflight, approval, and attempts click on example.com (UIA target finding is limited v1)",
  "stopOnFirstFailure": true,
  "steps": [
    { "id": "open-web", "kind": "browser.open", "path": "https://example.com", "saveAs": "browser.s1", "timeoutMs": 15000, "args": { "browser": "edge", "forceAccessibility": "true", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 3000 },
    { "id": "read-before", "kind": "browser.read", "process": "msedge", "property": "title", "saveAs": "btBefore", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "preflight", "kind": "preflight.click", "saveAs": "clickPreflight", "args": { "targettext": "More information..." } },
    { "id": "approval", "kind": "approval.manifest", "saveAs": "approval", "args": { "from": "clickPreflight", "mode": "nonCommercialWeb" } },
    { "id": "assert-exec-allowed", "kind": "assert.equals", "value": "{{approval.executionAllowedInThisHito}}", "expected": "true" },
    { "id": "safe-click", "kind": "safe.click", "saveAs": "safeClick", "args": { "targettext": "More information...", "approvalprefix": "approval" }, "continueOnError": true },
    { "id": "close-web", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "note-report", "kind": "note", "text": "Non-commercial safe click: approval allowed=true, click executed={{safeClick.executed}}, result={{safeClick.result}}. UIA target finding limited in v1." }
  ]
}
