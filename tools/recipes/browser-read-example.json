{
  "name": "browser-read-example",
  "description": "Browser read: open Edge, read title via UIA, assert contains Example",
  "stopOnFirstFailure": true,
  "steps": [
    {
      "id": "open-edge",
      "kind": "browser.open",
      "path": "https://example.com",
      "timeoutMs": 15000,
      "args": {
        "browser": "edge",
        "forceAccessibility": "true"
      }
    },
    {
      "id": "delay-load",
      "kind": "delay",
      "timeoutMs": 4000
    },
    {
      "id": "read-title",
      "kind": "browser.read",
      "process": "msedge",
      "property": "title",
      "saveAs": "browser.title",
      "timeoutMs": 10000
    },
    {
      "id": "assert-title",
      "kind": "assert.contains",
      "value": "{{browser.title}}",
      "expected": "Example"
    },
    {
      "id": "note-read",
      "kind": "note",
      "text": "Browser title read successfully: {{browser.title}}"
    }
  ]
}
