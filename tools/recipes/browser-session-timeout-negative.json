{
  "name": "browser-session-timeout-negative",
  "description": "Negative: force timeout on impossible browser detection with very short timeout",
  "stopOnFirstFailure": true,
  "steps": [
    {
      "id": "open-impossible",
      "kind": "browser.open",
      "path": "https://example.com",
      "saveAs": "browser.session",
      "timeoutMs": 500,
      "args": {
        "browser": "__NONEXISTENT_BROWSER__",
        "reuseExisting": "false"
      }
    }
  ]
}
