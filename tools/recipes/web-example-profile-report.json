{
  "name": "web-example-profile-report",
  "description": "Load example.com profile, open owned session, read title, close, assert using profile vars, report to Notepad",
  "stopOnFirstFailure": true,
  "metadata": {
    "category": "legacy",
    "cleanupRisk": "high",
    "autoRegression": false,
    "reason": "Browser session closes, but the recipe writes a dirty Notepad report and must remain manual."
  },
  "steps": [
    { "id": "load-profile", "kind": "profile.load", "path": "tools/profiles/web/example-com.json", "saveAs": "profile.example" },
    { "id": "open-web", "kind": "browser.open", "path": "{{profile.example.url}}", "saveAs": "browser.s1", "timeoutMs": 15000, "args": { "browser": "edge", "forceAccessibility": "true", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 4000 },
    { "id": "read-title", "kind": "browser.read", "process": "msedge", "property": "title", "saveAs": "browser.title", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "close-web", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "assert-title", "kind": "assert.contains", "value": "{{browser.title}}", "expected": "{{profile.example.expected.titleContains}}" },
    { "id": "open-notepad", "kind": "app.open", "app": "notepad" },
    { "id": "wait-notepad", "kind": "wait", "process": "Notepad", "titleContains": "Bloc de notas", "timeoutMs": 5000 },
    { "id": "focus-notepad", "kind": "key", "process": "Notepad", "text": "Enter", "continueOnError": true },
    { "id": "write-report", "kind": "actv.type", "process": "Notepad", "role": "Window", "text": "ONE BRAIN WEB REPORT\r\nProfile: {{profile.example.id}}\r\nURL: {{profile.example.url}}\r\nTitle: {{browser.title}}\r\nPASS" },
    { "id": "note-done", "kind": "note", "text": "Web profile report for {{profile.example.id}} completed." }
  ]
}
