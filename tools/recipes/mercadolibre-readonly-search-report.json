{
  "name": "mercadolibre-readonly-search-report",
  "description": "Mercado Libre Argentina read-only: search notebooks, read results, close, report. No login, no cart, no purchase.",
  "stopOnFirstFailure": true,
  "steps": [
    { "id": "load-profile", "kind": "profile.load", "path": "tools/profiles/web/mercadolibre-ar-notebook.json", "saveAs": "profile.ml" },
    { "id": "open-ml", "kind": "browser.open", "path": "{{profile.ml.url}}", "saveAs": "browser.s1", "timeoutMs": 20000, "args": { "browser": "edge", "forceAccessibility": "true", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 6000 },
    { "id": "read-title", "kind": "browser.read", "process": "msedge", "property": "title", "saveAs": "bt", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "read-text", "kind": "browser.read", "process": "msedge", "property": "text", "saveAs": "btext", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "close-ml", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "assert-title", "kind": "assert.contains", "value": "{{bt}}", "expected": "{{profile.ml.expected.titleContains}}" },
    { "id": "note-report", "kind": "note", "text": "ML Read-Only: {{profile.ml.url}} | Title: {{bt}} | Text sample: {{btext}}" }
  ]
}
