{
  "name": "browser-session-example",
  "description": "Browser session: open new owned window, read title via session, close owned window",
  "stopOnFirstFailure": true,
  "steps": [
    {
      "id": "open-session",
      "kind": "browser.open",
      "path": "https://example.com",
      "saveAs": "browser.session",
      "timeoutMs": 15000,
      "args": {
        "browser": "edge",
        "forceAccessibility": "true",
        "reuseExisting": "false"
      }
    },
    {
      "id": "delay-load",
      "kind": "delay",
      "timeoutMs": 4000
    },
    {
      "id": "read-title",
      "kind": "browser.read",
      "process": "msedge",
      "property": "title",
      "saveAs": "browser.title",
      "timeoutMs": 10000,
      "args": {
        "session": "browser.session"
      }
    },
    {
      "id": "assert-title",
      "kind": "assert.contains",
      "value": "{{browser.title}}",
      "expected": "Example"
    },
    {
      "id": "close-session",
      "kind": "browser.close",
      "saveAs": "browser.session",
      "timeoutMs": 5000
    },
    {
      "id": "note-done",
      "kind": "note",
      "text": "Browser session opened, read via session, and closed successfully."
    }
  ]
}
