{
  "name": "mercadolibre-click-preflight-report",
  "description": "ML product: open, read, close, discover, plan, preflight.click on Comprar ahora, approval.manifest. Zero clicks.",
  "stopOnFirstFailure": true,
  "steps": [
    { "id": "load-profile", "kind": "profile.load", "path": "tools/profiles/web/mercadolibre-ar-product.json", "saveAs": "profile.mlProduct" },
    { "id": "open-ml", "kind": "browser.open", "path": "{{profile.mlProduct.url}}", "saveAs": "browser.s1", "timeoutMs": 20000, "args": { "browser": "edge", "forceAccessibility": "true", "reuseExisting": "false" } },
    { "id": "delay-load", "kind": "delay", "timeoutMs": 6000 },
    { "id": "read-title", "kind": "browser.read", "process": "msedge", "property": "title", "saveAs": "bt", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "read-text", "kind": "browser.read", "process": "msedge", "property": "text", "saveAs": "btext", "timeoutMs": 10000, "args": { "session": "browser.s1" } },
    { "id": "close-ml", "kind": "browser.close", "saveAs": "browser.s1", "timeoutMs": 5000 },
    { "id": "discover", "kind": "discover.actionableelements", "saveAs": "actions" },
    { "id": "preflight", "kind": "preflight.click", "saveAs": "clickPreflight", "args": { "targettext": "Comprar ahora", "from": "{{actions.itemsJson}}" } },
    { "id": "approval", "kind": "approval.manifest", "saveAs": "approval" },
    { "id": "assert-decision", "kind": "assert.contains", "value": "{{clickPreflight.decision}}", "expected": "block" },
    { "id": "assert-exec-false", "kind": "assert.equals", "value": "{{approval.executionAllowedInThisHito}}", "expected": "false" },
    { "id": "note-report", "kind": "note", "text": "ML Preflight: {{clickPreflight.targetText}} → {{clickPreflight.decision}} | Blocked: {{clickPreflight.blocked}} | Executable: {{approval.executionAllowedInThisHito}}" }
  ]
}
