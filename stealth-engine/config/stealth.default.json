{
  "bridgeHost": "127.0.0.1",
  "bridgePort": 8787,

  "cloakbrowserExecutablePath": "",

  "fingerprint": {
    "defaultPreset": "desktop-win-chrome",
    "autoRotate": false,
    "canvasNoise": true,
    "audioNoise": true,
    "webglSpoof": true,
    "webrtcBlock": true
  },

  "tlsFingerprint": {
    "enabled": false,
    "impersonate": "chrome131",
    "useStealthPlugin": true,
    "tlsProxy": {
      "enabled": false,
      "type": "cycletls",
      "endpoint": ""
    }
  },

  "proxy": {
    "enabled": false,
    "rotationMode": "sticky",
    "providers": {
      "brightdata": { "enabled": false, "apiKey": "", "zone": "", "port": 22225 },
      "oxylabs": { "enabled": false, "username": "", "password": "", "endpoint": "", "country": "US" },
      "iproyal": { "enabled": false, "apiKey": "", "endpoint": "" }
    },
    "staticProxies": [],
    "healthCheckIntervalMs": 60000,
    "healthCheckConcurrency": 10,
    "reputation": {
      "reputationTtlMs": 3600000,
      "maxReputationEntries": 2000,
      "failureThreshold": 0.6,
      "minSamples": 3
    },
    "predictive": {
      "predictiveRotation": true,
      "minRiskScore": 0.5
    },
    "rateLimit": {
      "baseDelayMs": 1000,
      "minDelayMs": 200,
      "maxDelayMs": 60000,
      "backoffMultiplier": 2.0,
      "recoveryFactor": 0.9
    }
  },

  "antiBlocking": {
    "maxRecoveryAttempts": 5,
    "baseBackoffMs": 5000,
    "maxBackoffMs": 120000,
    "rotateProxyOnBlock": true,
    "rotateProfileOnBlock": false,
    "domainBlacklistSize": 100
  },

  "behavior": {
    "defaultProfile": "casual",
    "adaptive": true,
    "profileVariance": 0.2,
    "profiles": {
      "casual": { "typoRate": 0.03, "baseDelay": 80, "clickPauseMin": 80, "clickPauseMax": 230, "scrollPauseMs": 1500 },
      "pro": { "typoRate": 0.01, "baseDelay": 40, "clickPauseMin": 50, "clickPauseMax": 150, "scrollPauseMs": 600 },
      "elderly": { "typoRate": 0.05, "baseDelay": 150, "clickPauseMin": 150, "clickPauseMax": 400, "scrollPauseMs": 3000 }
    }
  },

  "visualCaptcha": {
    "enabled": false,
    "ocrEngine": "tesseract",
    "aiVision": {
      "enabled": false,
      "provider": "openai",
      "apiKey": "",
      "model": "gpt-4-vision-preview",
      "consentGiven": false
    }
  },

  "fingerprintEvolution": {
    "runOnStartup": false
  },

  "learning": {
    "domainProfile": {
      "filePath": "./src/data/domain-profiles.json",
      "maxDomains": 500,
      "ttlMs": 2592000000
    }
  },

  "captcha": {
    "twoCaptchaApiKey": "",
    "capSolverApiKey": ""
  }
}
